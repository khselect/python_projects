# ---- PostgreSQL ----
POSTGRES_USER=air
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=air_traffic
POSTGRES_PORT=5433          # 맥미니에서 이미 5432를 다른 서비스가 쓰고 있을 수 있어 기본값을 5433으로 지정

# ---- Backend(FastAPI) ----
DATABASE_URL=postgresql+psycopg2://air:change_me_strong_password@postgres:5432/air_traffic
BACKEND_PORT=8010           # 호스트에 노출할 포트(디버깅/직접 호출용, 선택)

# ---- Frontend(Streamlit) ----
BACKEND_URL=http://backend:8000
FRONTEND_PORT=8501          # Cloudflare Tunnel ingress가 바라볼 로컬 포트
